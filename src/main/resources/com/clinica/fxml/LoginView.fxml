<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20.0" alignment="CENTER" prefWidth="400.0" prefHeight="360.0"
      styleClass="login-bg"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.clinica.controller.LoginController">

    <padding>
        <Insets top="40" right="45" bottom="40" left="45"/>
    </padding>

    <VBox spacing="5.0" alignment="CENTER">
        <Label text="Clínica EXAME IV" styleClass="title-label"/>
        <Label text="Painel de Segurança e Autenticação" styleClass="subtitle-label"/>
    </VBox>

    <VBox spacing="6.0" alignment="CENTER_LEFT" fillWidth="true">
        <Label text="Utilizador (Login):" styleClass="field-label"/>
        <TextField fx:id="txtLogin" promptText="Introduza o seu login de acesso"/>
    </VBox>

    <VBox spacing="6.0" alignment="CENTER_LEFT" fillWidth="true">
        <Label text="Palavra-passe (Senha):" styleClass="field-label"/>
        <PasswordField fx:id="txtSenha" promptText="Introduza a sua senha"/>
    </VBox>

    <Button text="Entrar no Sistema" onAction="#handleLogin" prefWidth="220.0" styleClass="btn-primary"/>
</VBox>